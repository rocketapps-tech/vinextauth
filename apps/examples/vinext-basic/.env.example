# Auth secret — generate with: openssl rand -base64 32
VINEXTAUTH_SECRET=your-secret-here

# App URL (update for production)
VINEXTAUTH_URL=http://localhost:3002

# Google OAuth
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials
# 3. Add http://localhost:3002/api/auth/callback/google as redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# 1. Go to https://github.com/settings/applications/new
# 2. Set Homepage URL to http://localhost:3002
# 3. Set Callback URL to http://localhost:3002/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
