{
  "name": "vinextauth-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.10.1",
  "workspaces": [
    "packages/*",
    "docs",
    "apps/dev/vinext",
    "apps/examples/vinext-basic"
  ],
  "scripts": {
    "dev:docs": "npm run dev --workspace=docs",
    "build:docs": "npm run build --workspace=docs",
    "deploy:docs": "npm run deploy --workspace=docs",
    "typecheck": "npm run typecheck:pkg && npm run typecheck:docs",
    "typecheck:docs": "npm run typecheck --workspace=docs",
    "build:pkg": "npm run build --workspace=packages/vinext-auth",
    "dev:pkg": "npm run dev --workspace=packages/vinext-auth",
    "typecheck:pkg": "npm run typecheck --workspace=packages/vinext-auth",
    "test": "npm run test --workspace=packages/vinext-auth",
    "test:watch": "npm run test:watch --workspace=packages/vinext-auth",
    "dev:vinext": "npm run dev --workspace=apps/dev/vinext",
    "dev:example-vinext": "npm run dev --workspace=apps/examples/vinext-basic",
    "lint": "eslint packages/vinext-auth/src",
    "lint:fix": "eslint packages/vinext-auth/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "packages/vinext-auth/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
