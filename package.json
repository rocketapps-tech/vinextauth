{
  "name": "vinextauth-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.10.1",
  "workspaces": [
    "packages/*",
    "apps/dev/vinext",
    "apps/examples/vinext-basic"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "deploy": "vinext deploy",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-rsc.mjs",
    "build:pkg": "npm run build --workspace=packages/vinext-auth",
    "dev:pkg": "npm run dev --workspace=packages/vinext-auth",
    "typecheck:pkg": "npm run typecheck --workspace=packages/vinext-auth",
    "test": "npm run test --workspace=packages/vinext-auth",
    "test:watch": "npm run test:watch --workspace=packages/vinext-auth",
    "dev:vinext": "npm run dev --workspace=apps/dev/vinext",
    "dev:example-vinext": "npm run dev --workspace=apps/examples/vinext-basic",
    "lint": "eslint packages/vinext-auth/src",
    "lint:fix": "eslint packages/vinext-auth/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "fumadocs-core": "latest",
    "fumadocs-ui": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "vinext": "latest",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@cloudflare/vite-plugin": "latest",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-rsc": "^0.5.21",
    "eslint": "^9.0.0",
    "fumadocs-mdx": "^14.2.11",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "packages/vinext-auth/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
