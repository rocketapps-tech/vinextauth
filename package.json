{
  "name": "vinextauth-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.10.1",
  "workspaces": [
    "packages/*",
    "apps/**"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/vinext-auth",
    "dev": "npm run dev --workspace=packages/vinext-auth",
    "typecheck": "npm run typecheck --workspace=packages/vinext-auth",
    "test": "npm run test --workspace=packages/vinext-auth",
    "test:watch": "npm run test:watch --workspace=packages/vinext-auth",
    "lint": "eslint packages/vinext-auth/src",
    "lint:fix": "eslint packages/vinext-auth/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "semantic-release",
    "prepare": "husky",
    "dev:vinext": "npm run dev --workspace=apps/dev/vinext",
    "dev:example-vinext": "npm run dev --workspace=apps/examples/vinext-basic",
    "dev:docs": "npm run dev --workspace=apps/docs"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "packages/vinext-auth/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
